{
  "title": "MRFE API Overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "targets": [
        {
          "expr": "sum(rate(mrfe_http_requests_total[1m])) by (path)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(mrfe_http_request_duration_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Slow Query Count",
      "targets": [
        {
          "expr": "sum(mrfe_slow_query_total)"
        }
      ]
    }
  ]
}
