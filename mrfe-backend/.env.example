ENVIRONMENT=development
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./mrfe.db
REDIS_URL=redis://localhost:6379/0
MONGO_URL=mongodb://localhost:27017
MONGO_DATABASE=mrfe
MONGO_NEWS_COLLECTION=news_events
NEWSAPI_API_KEY=
NEWSAPI_QUERY=markets OR stocks OR economy OR earnings
NEWSAPI_SOURCES=
NEWSAPI_LANGUAGE=en
NEWSAPI_PAGE_SIZE=50
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHAVANTAGE_PAGE_SIZE=50
JWT_PRIVATE_KEY=dev-private-key
JWT_PUBLIC_KEY=dev-private-key
SERVICE_API_KEYS_CSV=
RATE_LIMIT_PER_MINUTE=120
LOG_LEVEL=INFO
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://mrfe.local
OPENROUTER_X_TITLE=MRFE Backend
OPENROUTER_PRIMARY_MODEL=openai/gpt-4o-mini
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_SECONDS=30.0
OPENROUTER_MAX_RETRIES=2
OPENROUTER_MONTHLY_BUDGET_USD=0
OPENROUTER_MAX_COST_USD_PER_REQUEST=0
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-opus-latest
ANTHROPIC_TIMEOUT_SECONDS=30.0
ANTHROPIC_VERSION=2023-06-01
MODEL_REGISTRY_PATH=storage/model_registry.json
DRIFT_ALERT_THRESHOLD=0.18
ENSEMBLE_REGIME_WEIGHT=0.35
