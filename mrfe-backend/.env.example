# Application Settings
APP_NAME=MRFE Backend
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1

# Database Settings
DATABASE_URL=sqlite+aiosqlite:///./mrfe.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_ECHO=false

# Redis Settings
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# Security Settings
SECRET_KEY=change-me
JWT_PRIVATE_KEY=dev-private-key
JWT_PUBLIC_KEY=dev-public-key
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings
CORS_ORIGINS=["*"]

# ML/Processing Settings
ML_MODEL_TIMEOUT=30
MAX_CONCURRENT_PROCESSING=10
EVENT_DETECTION_CONFIDENCE_THRESHOLD=0.5

# Monitoring Settings
ENABLE_TRACING=true
ENABLE_METRICS=true
LOG_LEVEL=INFO

# External API Settings
NEWSAPI_BASE_URL=https://newsapi.org/v2
NEWSAPI_API_KEY=
NEWSAPI_QUERY=markets OR stocks OR economy OR earnings
NEWSAPI_SOURCES=
NEWSAPI_LANGUAGE=en
NEWSAPI_PAGE_SIZE=50
ALPHAVANTAGE_API_KEY=

# OpenRouter / LLM Settings (optional)
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
